{
    "name": "example/refactor-cakephp-settings",
    "description": "Incremental refactoring example for a CakePHP 4.5 settings screen",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "cakephp/cakephp": "4.5.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "init-db": "php scripts/init-db.php",
        "serve": "php -S 127.0.0.1:8765 -t webroot webroot/index.php",
        "test": "php tests/run.php"
    }
}
